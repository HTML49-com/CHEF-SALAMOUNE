<style>
:root { --gold: #c5a059; --dark: #0a0a0a; --card: #151515; }

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: var(--dark);
    color: white;
    margin: 0;
}

/* HEADER */
header {
    text-align: center;
    padding: 30px 20px;
    background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), 
    url('https://i.ibb.co/wZzhg9VP/IMG-xxxx.jpg');
    background-size: cover;
    border-bottom: 2px solid var(--gold);
}

.logo {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    border: 3px solid var(--gold);
    object-fit: cover;
}

h1 { color: var(--gold); margin-top: 10px; }

/* TITLES */
.section-title {
    background: var(--gold);
    color: black;
    padding: 8px 25px;
    text-align: center;
    margin: 20px auto;
    font-weight: bold;
    width: fit-content;
    border-radius: 5px;
}

/* GRID */
.special-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    padding: 15px;
}

.dish-card {
    background: var(--card);
    border-radius: 15px;
    overflow: hidden;
    text-align: center;
    border: 1px solid #222;
}

.dish-card img {
    width: 100%;
    height: 120px;
    object-fit: cover;
}

.dish-info h3 { 
    font-size: 13px; 
    margin: 8px 0;
    height: 32px; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
}

/* ORDER ROW (For Grid) */
.order-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 10px;
    background: #222;
}

/* زر الطلب ذهبي */
.mini-order-btn {
    background: var(--gold);
    color: black;
    padding: 4px 12px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: bold;
    cursor: pointer;
}

.price { color: var(--gold); font-weight: bold; font-size: 13px; }

/* SANDWICH STYLE - تعديل الزر لليمين */
.sandwich-item {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    padding: 15px;
    background: var(--card);
    border-bottom: 1px solid #222;
    margin: 0 15px;
}

.sandwich-item .mini-order-btn {
    margin-left: 15px;
}

.sandwich-item span:nth-child(2) {
    flex: 1;
    font-size: 14px;
}

/* MODAL */
.modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.9);
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-content {
    background: #111;
    padding: 25px;
    border-radius: 20px;
    width: 300px;
    border: 1px solid var(--gold);
    text-align: center;
}

input, textarea {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
    border-radius: 8px;
    border: none;
    background: #222;
    color: white;
    box-sizing: border-box;
}

.send-btn { 
    width: 100%; 
    padding: 12px; 
    border: none; 
    background: var(--gold); 
    font-weight: bold; 
    border-radius: 10px;
    cursor: pointer; 
}

.back-btn { 
    display: block; 
    margin-top: 15px; 
    color: #888; 
    cursor: pointer; 
    font-size: 13px;
}
</style>
</head>

