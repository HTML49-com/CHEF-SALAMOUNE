        <input type="tel" id="phone" placeholder="الهاتف">
        <textarea id="note" placeholder="ملاحظة"></textarea>
        <button class="send-btn" onclick="send()">إرسال واتساب</button>
        <span class="back-btn" onclick="closeModal()">رجوع</span>
    </div>
</div>

<script>
let selectedDish = "";
let selectedPrice = "";

function selectDish(name, price){
    selectedDish = name;
    selectedPrice = price;
    document.getElementById("dishName").innerText = name;
    document.getElementById("modal").style.display="flex";
}

function closeModal(){ 
    document.getElementById("modal").style.display="none"; 
}

function send(){
    let name = document.getElementById("name").value;
    let phone = document.getElementById("phone").value;
    let note = document.getElementById("note").value;
    
    if(!name || !phone){ 
        alert("عمر المعلومات"); 
        return; 
    }
    
    let msg = `طلب من Chef Salamoune 🍽️\nالاسم: ${name}\nالهاتف: ${phone}\nالطلب: ${selectedDish} (${selectedPrice})\nملاحظة: ${note}`;
    
    // التعديل باش يدوز للواتساب نيشان
    window.location.href = "https://wa.me/212772823521?text=" + encodeURIComponent(msg);
}
</script>

